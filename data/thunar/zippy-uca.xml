<action>
	<icon>archive-extract</icon>
	<name>Extract Here (Zippy)</name>
	<unique-id>zippy-extract-here</unique-id>
	<command>zippy --extract-here %F</command>
	<description>Extract archive(s) here</description>
	<patterns>*.zip;*.7z;*.rar;*.tar;*.gz;*.bz2;*.xz;*.zst;*.tgz;*.tbz2;*.txz;*.tar.gz;*.tar.bz2;*.tar.xz;*.tar.zst</patterns>
	<audio-files/>
	<image-files/>
	<other-files/>
	<text-files/>
	<video-files/>
</action>
